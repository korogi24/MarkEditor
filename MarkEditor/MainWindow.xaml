<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MarkEditor.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MarkEditor"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d"
    Title="MarkEditor">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar Grid.Row="0" x:Name="TitleBar" Title="MarkEditor">
            <TitleBar.Content>
                <AutoSuggestBox Width="360"
                                VerticalAlignment="Center"
                                PlaceholderText="検索"
                                QueryIcon="Find" />
            </TitleBar.Content>
        </TitleBar>

        <controls:TabbedCommandBar x:Name="TabbedCommandBar"
                                   Grid.Row="1"
                                   Margin="5,0">
            <controls:TabbedCommandBar.MenuItems>
                <controls:TabbedCommandBarItem Header="ファイル">

                    <AppBarButton Icon="Add" Label="新規作成" />
                    <AppBarButton Icon="OpenFile" Label="開く" />

                    <AppBarSeparator />

                    <AppBarButton Icon="Save" Label="上書き保存" />
                    <AppBarButton Icon="{ui:FontIcon Glyph=&#xE792;}" Label="名前をつけて保存" />

                    <AppBarSeparator />

                    <AppBarButton Icon="Setting" Label="設定" />
                    <AppBarButton Icon="{ui:FontIcon Glyph=&#xE946;}" Label="バージョン情報">
                        <AppBarButton.Flyout>
                            <Flyout>
                                <StackPanel>
                                    <TextBlock Style="{ThemeResource BaseTextBlockStyle}" Text="MarkEditor v.1.0.0" Margin="0,0,0,12" />
                                    <Expander Header="リンク" Width="157">
                                        <Expander.Content>
                                            <StackPanel>
                                                <HyperlinkButton Content="GitHub リポジトリ" NavigateUri="https://github.com/korogi24/MarkEditor" />
                                            </StackPanel>
                                        </Expander.Content>
                                    </Expander>
                                </StackPanel>
                            </Flyout>
                        </AppBarButton.Flyout>
                    </AppBarButton>
                    
                </controls:TabbedCommandBarItem>
                <controls:TabbedCommandBarItem x:Name="HomeTab" Header="ホーム" DefaultLabelPosition="Collapsed">

                    <AppBarElementContainer ToolTipService.ToolTip="元に戻す">
                        <SplitButton>
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="16"
                                      Glyph="&#xE7A7;" />
                            <SplitButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Icon="{ui:FontIcon Glyph=&#xE7A7;}" Text="元に戻す" />
                                    <MenuFlyoutItem Icon="{ui:FontIcon Glyph=&#xE7A6;}" Text="やり直し" />
                                </MenuFlyout>
                            </SplitButton.Flyout>
                        </SplitButton>
                    </AppBarElementContainer>
                    <AppBarElementContainer ToolTipService.ToolTip="クリップボード">
                        <SplitButton>
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="16"
                                      Glyph="&#xE77F;" />
                            <SplitButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Icon="Cut" Text="切り取り" />
                                    <MenuFlyoutItem Icon="Copy" Text="コピー" />
                                    <MenuFlyoutItem Icon="Paste" Text="貼り付け" />
                                    <MenuFlyoutItem Text="テキストのみ貼り付け">
                                        <MenuFlyoutItem.Icon>
